// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// Key-value хранилище для системных настроек (Telegram chatId и др.)
model SystemConfig {
  id        String   @id @default(cuid())
  key       String   @unique
  value     String
  updatedAt DateTime @updatedAt
}

model Product {
  id        String   @id @default(cuid())
  name      String
  price     Float
  imageUrl  String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}


